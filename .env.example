# Remote: https://openclaw.dadaex.cn
OPENCLAW_HTTP_URL=https://openclaw.dadaex.cn
OPENCLAW_TOKEN=your-auth-token-here

# Coze API Configuration
COZE_API_URL=https://api.coze.cn
COZE_TOKEN=your-coze-token-here
